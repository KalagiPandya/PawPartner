PORT=8000
MONGODB_URI=your_mongodb_uri_here
ACCESS_TOKEN_SECRET=your_access_token_secret_here
ACCESS_TOKEN_EXPIRY=7d
REFRESH_TOKEN_SECRET=your_refresh_token_secret_here
REFRESH_TOKEN_EXPIRY=30d
SESSION_SECRET=your_session_secret_here

# Cloudinary - add yours to enable image uploads (optional for basic testing)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name_here
CLOUDINARY_API_KEY=your_cloudinary_api_key_here
CLOUDINARY_API_SECRET=your_cloudinary_api_secret_here

# Google OAuth - add yours to enable Google sign-in (optional)
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_CALLBACK_URL=http://localhost:8000/api/v1/users/auth/google/callback

# SendGrid - add yours to enable emails (optional - app works without it)
SENDGRID_API_KEY=your_sendgrid_api_key_here
VERIFIED_SENDER_EMAIL=your_verified_sender_email_here
